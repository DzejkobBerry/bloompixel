<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <radialGradient id="robotBg" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:rgba(139, 92, 246, 0.2);stop-opacity:1" />
      <stop offset="50%" style="stop-color:rgba(6, 182, 212, 0.1);stop-opacity:1" />
      <stop offset="100%" style="stop-color:rgba(15, 23, 42, 0.8);stop-opacity:1" />
    </radialGradient>
    <pattern id="circuitPattern" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
      <rect width="40" height="40" fill="transparent"/>
      <circle cx="20" cy="20" r="2" fill="rgba(139, 92, 246, 0.3)"/>
      <path d="M0,20 L40,20 M20,0 L20,40" stroke="rgba(6, 182, 212, 0.2)" stroke-width="1"/>
    </pattern>
  </defs>
  
  <!-- Background gradient -->
  <rect width="100%" height="100%" fill="url(#robotBg)"/>
  
  <!-- Circuit pattern overlay -->
  <rect width="100%" height="100%" fill="url(#circuitPattern)" opacity="0.5"/>
  
  <!-- Floating geometric shapes -->
  <g opacity="0.3">
    <polygon points="100,50 120,80 80,80" fill="rgba(139, 92, 246, 0.4)">
      <animateTransform attributeName="transform" type="rotate" values="0 100 70;360 100 70" dur="20s" repeatCount="indefinite"/>
    </polygon>
    
    <rect x="650" y="100" width="30" height="30" fill="rgba(6, 182, 212, 0.4)" rx="5">
      <animateTransform attributeName="transform" type="rotate" values="0 665 115;-360 665 115" dur="15s" repeatCount="indefinite"/>
    </rect>
    
    <circle cx="200" cy="450" r="15" fill="rgba(236, 72, 153, 0.4)">
      <animate attributeName="cy" values="450;430;450" dur="8s" repeatCount="indefinite"/>
    </circle>
    
    <polygon points="600,400 620,430 580,430" fill="rgba(139, 92, 246, 0.4)">
      <animateTransform attributeName="transform" type="rotate" values="0 600 420;360 600 420" dur="25s" repeatCount="indefinite"/>
    </polygon>
  </g>
  
  <!-- Tech lines -->
  <g stroke="rgba(6, 182, 212, 0.3)" stroke-width="2" fill="none" opacity="0.6">
    <path d="M50,300 Q200,250 350,300 T650,300">
      <animate attributeName="stroke-dasharray" values="0,1000;1000,0;0,1000" dur="12s" repeatCount="indefinite"/>
    </path>
    <path d="M100,150 Q300,100 500,150 T750,150">
      <animate attributeName="stroke-dasharray" values="1000,0;0,1000;1000,0" dur="10s" repeatCount="indefinite"/>
    </path>
  </g>
</svg>