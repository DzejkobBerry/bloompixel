  <text x="200" y="60" text-anchor="middle" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#4285f4">Google</text>
  <text x="200" y="100" text-anchor="middle" font-family="Arial, sans-serif" font-size="14" fill="#4285f4">Certificate of Achievement</text>
  <text x="200" y="130" text-anchor="middle" font-family="Arial, sans-serif" font-size="15" font-weight="bold" fill="#4285f4">Google Analytics</text>
  <text x="200" y="150" text-anchor="middle" font-family="Arial, sans-serif" font-size="15" font-weight="bold" fill="#4285f4">Certified</text>
  <text x="200" y="190" text-anchor="middle" font-family="Arial, sans-serif" font-size="12" fill="#666">Awarded to: Developer</text>
  <text x="200" y="210" text-anchor="middle" font-family="Arial, sans-serif" font-size="12" fill="#666">Date: 2023</text>
  <rect x="160" y="230" width="80" height="20" fill="#4285f4" rx="10"/>
